/**app.scss**/
@import "/icons/font/iconfont.wxss";
@import "/icons/icon.wxss";
view, form, scroll-view, swiper, button, input, textarea, label, navigator, image {
	box-sizing: border-box;
}
view {
	font-size: 15px;
}
button {
	padding: 0;
	line-height: 2.5;
	font-size: 12px;
}
.container {
	height: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	justify-content: space-between;
	padding: 200rpx 0;
	box-sizing: border-box;
} 
