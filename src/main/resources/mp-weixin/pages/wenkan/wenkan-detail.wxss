.wenkan-detail-container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}
.page-header {
  background: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.content-scroll {
  flex: 1;
  background: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}
.wenkan-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}
.wenkan-content rich-text {
  width: 100%;
}
.wenkan-content rich-text p {
  margin-bottom: 20rpx;
  text-indent: 2em;
}
.wenkan-content rich-text h1,
.wenkan-content rich-text h2,
.wenkan-content rich-text h3 {
  font-weight: bold;
  margin: 30rpx 0 20rpx;
  color: #333;
}
.wenkan-content rich-text img {
  max-width: 100%;
  height: auto;
  margin: 20rpx 0;
  border-radius: 12rpx;
}
.wenkan-content rich-text blockquote {
  border-left: 4rpx solid #1890ff;
  padding-left: 20rpx;
  margin: 20rpx 0;
  background: #f5f5f5;
  padding: 20rpx;
  border-radius: 8rpx;
}
