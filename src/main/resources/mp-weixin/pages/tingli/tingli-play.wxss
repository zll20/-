.tingli-play-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 100rpx;
}

.page-header {
  background: #fff;
  padding: 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.audio-info {
  background: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}

.audio-name {
  font-size: 32rpx;
  color: #333;
  font-weight: 500;
}

.audio-player {
  margin: 30rpx;
}

.player-wrapper {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.progress-bar {
  margin-bottom: 20rpx;
}

.time-display {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.current-time,
.duration-time {
  font-size: 24rpx;
  color: #999;
}

.controls {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.control-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.control-icon {
  font-size: 80rpx;
  color: #fa6b04;
  margin-bottom: 10rpx;
}

.control-text {
  font-size: 28rpx;
  color: #333;
}

.speed-selector {
  display: flex;
  align-items: center;
  justify-content: center;
}

.speed-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
}

.speed-picker {
  display: flex;
  align-items: center;
  padding: 10rpx 30rpx;
  background: #f5f5f5;
  border-radius: 40rpx;
}

.speed-value {
  font-size: 28rpx;
  color: #fa6b04;
  font-weight: 500;
}

.speed-arrow {
  font-size: 20rpx;
  color: #999;
  margin-left: 10rpx;
}
