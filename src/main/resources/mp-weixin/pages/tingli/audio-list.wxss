
.tingli-audio-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 40rpx;
}
.page-header {
  background: #fff;
  padding: 40rpx 30rpx;
  text-align: center;
  border-bottom: 1rpx solid #eee;
}
.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}
.content-area {
  background: #fff;
  margin: 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
}
.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
.material-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
.material-item {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
}
.material-item::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -20%;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
}
.material-item::after {
  content: '';
  position: absolute;
  bottom: -30%;
  left: -10%;
  width: 150rpx;
  height: 150rpx;
  background: rgba(255,255,255,0.05);
  border-radius: 50%;
}
.material-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
  z-index: 1;
}
.material-icon {
  font-size: 56rpx;
  color: rgba(255,255,255,0.9);
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.15);
  border-radius: 50%;
  flex-shrink: 0;
}
.material-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
  flex: 1;
}
.material-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.material-jibie {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}
.material-right {
  display: flex;
  align-items: center;
  z-index: 1;
}
.play-btn {
  font-size: 48rpx;
  color: rgba(255,255,255,0.9);
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
}
.material-item:active {
  opacity: 0.9;
  transform: scale(0.98);
}
