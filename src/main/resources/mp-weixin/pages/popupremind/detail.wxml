<wxs src="../../utils/format.wxs" module="format" />
<view class="content">
	<view class="detail-container">
		<view class="detail-content">

			<view class="detail-list-item">
				<view class="label">角色：</view>
				<view class="text" >{{detail.role}}</view>
			</view>
			<view class="detail-list-item">
				<view class="label">标题：</view>
				<view class="text" >{{detail.title}}</view>
			</view>
			<view class="detail-list-item">
				<view class="label">类型：</view>
				<view class="text" >{{detail.type}}</view>
			</view>
			<view class="detail-list-item">
				<view class="label">提醒时间：</view>
				<view class="text" >{{detail.remindtime}}</view>
			</view>



			<view class="detail-list-item">
				<view class="label">简介：</view>
				<view class="text">{{detail.brief}}</view>
			</view>


			<view class="detail-rich-item">
				<view class="label">内容：</view>
				<view class="rich-text">
					<rich-text nodes="{{detail.content}}"></rich-text>
				</view>
			</view>



			<view class="bottom-content bg-white button-box">

			</view>
		</view>
	</view>
	<view class="scrollTop" wx:if="{{scrollTop>200}}" bindtap="scrollTopClick">
		<span class="icon iconfont icon-jiantou07"></span>
	</view>
</view>