er=\"日期\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"学习时长\" prop=\"xuexishizhang\" >\r\n\t\t\t\t\t<el-input-number v-model=\"ruleForm.xuexishizhang\" placeholder=\"学习时长\" :disabled=\"ro.xuexishizhang\"></el-input-number>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"学习时长\" prop=\"xuexishizhang\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.xuexishizhang\" placeholder=\"学习时长\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"学习任务\" prop=\"xuexirenwu\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.xuexirenwu\" placeholder=\"学习任务\" clearable  :readonly=\"ro.xuexirenwu\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"学习任务\" prop=\"xuexirenwu\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.xuexirenwu\" placeholder=\"学习任务\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"复习计划\" prop=\"fuxijihua\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.fuxijihua\" placeholder=\"复习计划\" clearable  :readonly=\"ro.fuxijihua\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"复习计划\" prop=\"fuxijihua\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.fuxijihua\" placeholder=\"复习计划\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t</template>\r\n\t\t\t<el-form-item class=\"btn\">\r\n\t\t\t\t<el-button class=\"btn3\"  v-if=\"type!='info'\" type=\"success\" @click=\"onSubmit\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-queren15\"></span>\r\n\t\t\t\t\t提交\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn4\" v-if=\"type!='info'\" type=\"success\" @click=\"back()\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-guanbi2\"></span>\r\n\t\t\t\t\t取消\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn5\" v-if=\"type=='info'\" type=\"success\" 