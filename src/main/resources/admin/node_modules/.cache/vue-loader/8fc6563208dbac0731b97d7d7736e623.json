AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"add-or-update.vue","sourceRoot":"src/views/modules/popupremind","sourcesContent":["\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<template>\r\n\t<div class=\"addEdit-block\">\r\n\t\t<el-form\r\n\t\t\tclass=\"add-update-preview\"\r\n\t\t\tref=\"ruleForm\"\r\n\t\t\t:model=\"ruleForm\"\r\n\t\t\t:rules=\"rules\"\r\n\t\t\tlabel-width=\"140px\"\r\n\t\t>\r\n\t\t\t<template >\r\n\t\t\t\t<template v-if=\"ruleForm.type=='个人'\">\r\n\t\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"角色\" prop=\"role\">\r\n\t\t\t\t\t\t<el-select filterable v-model=\"ruleForm.role\" placeholder=\"角色\" @change=\"roleChange\">\r\n\t\t\t\t\t\t\t<el-option v-for=\"item in roleList\" :label=\"item.tableName\" :value=\"item.roleName\"></el-option>\r\n\t\t\t\t\t\t</el-select>\r\n\t\t\t\t\t</el-form-item>\r\n\t\t\t\t\t<el-form-item v-else class=\"input\" label=\"角色\" prop=\"role\" >\r\n\t\t\t\t\t\t{{changeRoleName(ruleForm.role)}}\r\n\t\t\t\t\t</el-form-item>\r\n\t\t\t\t</template>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'&&ruleForm.type=='个人'\"  label=\"用户\" prop=\"userid\">\r\n\t\t\t\t\t<el-select filterable v-model=\"ruleForm.userid\" placeholder=\"用户\">\r\n\t\t\t\t\t\t<el-option v-for=\"item in userList\" :label=\"item.account\" :value=\"item.id\"></el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"标题\" prop=\"title\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.title\" placeholder=\"标题\" clearable  :readonly=\"ro.title\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"标题\" prop=\"title\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.title\" placeholder=\"标题\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"select\" v-if=\"type!='info'\"  label=\"类型\" prop=\"type\" >\r\n\t\t\t\t\t<el-select :disabled=\"ro.type\" v-model=\"ruleForm.type\" placeholder=\"请选择类型\"  filterable>\r\n\t\t\t\t\t\t<el-option\r\n\t\t\t\t\t\t\tv-for=\"(item,index) in typeOptions\"\r\n\t\t\t\t\t\t\tv-bind:key=\"index\"\r\n\t\t\t\t\t\t\t:label=\"item\"\r\n\t\t\t\t\t\t\t:value=\"item\">\r\n\t\t\t\t\t\t</el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"类型\" prop=\"type\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.type\"\r\n\t\t\t\t\t\tplaceholder=\"类型\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"date\" v-if=\"type!='info'\" label=\"提醒时间\" prop=\"remindtime\" >\r\n\t\t\t\t\t<el-date-picker\r\n\t\t\t\t\t\tvalue-format=\"yyyy-MM-dd HH:mm:ss\"\r\n\t\t\t\t\t\tv-model=\"ruleForm.remindtime\" \r\n\t\t\t\t\t\ttype=\"datetime\"\r\n\t\t\t\t\t\t:readonly=\"ro.remindtime\"\r\n\t\t\t\t\t\tplaceholder=\"提醒时间\"\r\n\t\t\t\t\t></el-date-picker>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-else-if=\"ruleForm.remindtime\" label=\"提醒时间\" prop=\"remindtime\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.remindtime\" placeholder=\"提醒时间\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t</template>\r\n\t\t\t<el-form-item class=\"textarea\" v-if=\"type!='info'\" label=\"简介\" prop=\"brief\" >\r\n\t\t\t\t<el-input\r\n\t\t\t\t\tstyle=\"min-width: 200px; max-width: 600px;\"\r\n\t\t\t\t\ttype=\"textarea\"\r\n\t\t\t\t\t:rows=\"8\"\r\n\t\t\t\t\tplaceholder=\"简介\"\r\n\t\t\t\t\tv-model=\"ruleForm.brief\" >\r\n\t\t\t\t</el-input>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item v-else-if=\"ruleForm.brief\" label=\"简介\" prop=\"brief\"  class=\"textBox\">\r\n\t\t\t\t<span class=\"text\">{{ruleForm.brief}}</span>\r\n\t\t\t</el-form-item>\r\n\t\t\t<el-form-item v-if=\"type!='info'\" class=\"editorBox\" label=\"内容\" prop=\"content\" >\r\n\t\t\t\t<editor \r\n\t\t\t\t\tstyle=\"min-width: 200px; max-width: 600px;\"\r\n\t\t\t\t\tv-model=\"ruleForm.content\" \r\n\t\t\t\t\tclass=\"editor\"\r\n\t\t\t\t\tmyQuillEditor=\"content\"\r\n\t\t\t\t\tactio