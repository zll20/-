\n\r\n\r\n\r\n\r\n<template>\r\n\t<div class=\"addEdit-block\">\r\n\t\t<el-form\r\n\t\t\tclass=\"add-update-preview\"\r\n\t\t\tref=\"ruleForm\"\r\n\t\t\t:model=\"ruleForm\"\r\n\t\t\t:rules=\"rules\"\r\n\t\t\tlabel-width=\"140px\"\r\n\t\t>\r\n\t\t\t<template >\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"手机\" prop=\"mobile\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.mobile\" placeholder=\"手机\" clearable  :readonly=\"ro.mobile\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"手机\" prop=\"mobile\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.mobile\" placeholder=\"手机\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"角色\" prop=\"role\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.role\" placeholder=\"角色\" clearable  :readonly=\"ro.role\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"角色\" prop=\"role\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.role\" placeholder=\"角色\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item class=\"input\" v-if=\"type!='info'\"  label=\"验证码\" prop=\"code\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.code\" placeholder=\"验证码\" clearable  :readonly=\"ro.code\"></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t\t<el-form-item v-else class=\"input\" label=\"验证码\" prop=\"code\" >\r\n\t\t\t\t\t<el-input v-model=\"ruleForm.code\" placeholder=\"验证码\" readonly></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t</template>\r\n\t\t\t<el-form-item class=\"btn\">\r\n\t\t\t\t<el-button class=\"btn3\"  v-if=\"type!='info'\" type=\"success\" @click=\"onSubmit\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-queren15\"></span>\r\n\t\t\t\t\t提交\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn4\" v-if=\"type!='info'\" type=\"success\" @click=\"back()\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-guanbi2\"></span>\r\n\t\t\t\t\t取消\r\n\t\t\t\t</el-button>\r\n\t\t\t\t<el-button class=\"btn5\" v-if=\"type=='info'\" type=\"success\" @click=\"back()\">\r\n\t\t\t\t\t<span class=\"icon iconfont icon-fanhui13\"></span>\r\n\t\t\t\t\t返回\r\n\t\t\t\t</el-button>\r\n\t\t\t</el-form-item>\r\n\t\t</el-form>\r\n    \r\n\r\n\t</div>\r\n</template>\r\n<script>\r\n\texport default {\r\n\t\tdata() {\r\n\t\t\treturn {\r\n\t\t\t\tid: '',\r\n\t\t\t\ttype: '',\r\n\t\t\t\r\n\t\t\t\r\n\t\t\t\tro:{\r\n\t\t\t\t\tmobile : false,\r\n\t\t\t\t\trole : false,\r\n\t\t\t\t\tcode : false,\r\n\t\t\t\t},\r\n\t\t\t\r\n\t\t\t\truleForm: {\r\n\t\t\t\t\tmobile: '',\r\n\t\t\t\t\trole: '',\r\n\t\t\t\t\tcode: '',\r\n\t\t\t\t},\r\n\r\n\t\t\t\trules: {\r\n\t\t\t\t\tmobile: [\r\n\t\t\t\t\t\t{ required: true, message: '手机不能为空', trigger: 'blur' },\r\n\t\t\t\t\t],\r\n\t\t\t\t\trole: [\r\n\t\t\t\t\t\t{ required: true, message: '角色不能为空', trigger: 'blur' },\r\n\t\t\t\t\t],\r\n\t\t\t\t\tcode: [\r\n\t\t\t\t\t\t{ required: true, message: '验证码不能为空', trigger: 'blur' },\r\n\t\t\t\t\t],\r\n\t\t\t\t},\r\n\t\t\t};\r\n\t\t},\r\n\t\tprops: [\"parent\"],\r\n\t\tcomputed: {\r\n\t\t\tsessionForm() {\r\n\t\t\t\treturn JSON.parse(this.$storage.getObj('userForm'))\r\n\t\t\t},\r\n\t\t\tsessionTable() {\r\n\t\t\t\treturn this.$storage.get('sessionTable')\r\n\t\t\t},\r\n\r\n\r\n\r\n\t\t},\r\n\t\tcomponents: {\r\n\t\t},\r\n\t\tcreated() {\r\n\t\t},\r\n\t\tmethods: {\r\n\t\t\timgPreView(url){\r\n\t\t\t\tthis.$parent.imgPreView(url)\r\n\t\t\t},\r\n\t\t\t// 下载\r\n\t\t\tdownload(file){\r\n\t\t\t\twindow.open(`${file}`)\r\n\t\t\t},\r\n\t\t\t// 初始化\r\n\t\t\tinit(id,type ) {\r\n\t\t\t\tif (id) {\r\n\t\t\t\t\tthis.id = id;\r\n\t\t\t\t\tthis.type = type;\r\n\t\t\t\t}\r\n\t\t\t\tif(this.type=='info'||this.type=='else'||this.type=='msg'){\r\n\t\t\t\t\tthis.info(id);\r\n\t\t\t\t}else if(this.type=='logistics'){\r\n\t\t\t\t\tfor(let x in this.ro) {\r\n\t\t\t\t\t\tthis.ro[x] = true\r\n\t\t\t\t\t}\r\n\t\t\t\t\tthis.logistics=false;\r\n\t\t\t\t\tthis.info(id);\r\n\t\t\t\t}else if(this.type=='cross'){\r\n\t\t\t\t\tvar obj = this.$storage.getObj('crossObj');\r\n\t\t\t\t\tfor (var o in obj){\r\n\t\t\t\t\t\tif(o=='mobile'){\r\n\t\t\t\t\t\t\tthis.ruleForm.mobile = obj[o];\r\n\t\t\t\t\t\t\tthis.ro.mobile = true;\r\n\t\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tif(o=='role'){\r\n\t\t\t\t\t\t\tthis.ruleForm.role = obj[o];\r\n\t\t\t\t\t\t\tthis.ro.role = true;\r\n\t\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tif(o=='code'){\r\n\t\t\t\t\t\t\tthis.ruleForm.code = obj[o];\r\n\t\t\t\t\t\t\tthis.ro.code = true;\r\n\t\t\t\t\t\t\tcontinue;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\r\n\t\t\t\r\n\t\t\t},\r\n\t\t\t// 多级联动参数\r\n\r\n\t\t\tasync info(id) {\r\n\t\t\t\tawait this.$http({\r\n\t\t\t\t\turl: `smsregistercode/info/${id}`,\r\n\t\t\t\t\tmethod: \"get\"\r\n\t\t\t\t}).then(({ data }) => {\r\n\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\tthis.ruleForm = data.data;\r\n\t\t\t\t\t\t//解决前台上传图片后台不显示的问题\r\n\t\t\t\t\t\tlet reg=new RegExp('../../../upload','g')//g代表全部\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t},\r\n\r\n\t\t\t// 提交\r\n\t\t\tasync onSubmit() {\r\n\t\t\t\t\tvar objcross = this.$storage.getObj('crossObj');\r\n\t\t\t\t\tif(!this.ruleForm.id) {\r\n\t\t\t\t\t\tdelete this.ruleForm.userid\r\n\t\t\t\t\t}\r\n\t\t\t\t\tawait this.$refs[\"ruleForm\"].validate(async valid => {\r\n\t\t\t\t\t\tif (valid) {\r\n\t\t\t\t\t\t\tif(this.type=='cross'){\r\n\t\t\t\t\t\t\t\tvar statusColumnName = this.$storage.get('statusColumnName');\r\n\t\t\t\t\t\t\t\tvar statusColumnValue = this.$storage.get('statusColumnValue');\r\n\t\t\t\t\t\t\t\tif(statusColumnName!='') {\r\n\t\t\t\t\t\t\t\t\tvar obj = this.$storage.getObj('crossObj');\r\n\t\t\t\t\t\t\t\t\tif(statusColumnName && !statusColumnName.startsWith(\"[\")) {\r\n\t\t\t\t\t\t\t\t\t\tfor (var o in obj){\r\n\t\t\t\t\t\t\t\t\t\t\tif(o==statusColumnName){\r\n\t\t\t\t\t\t\t\t\t\t\t\tobj[o] = statusColumnValue;\r\n\t\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t\tvar table = this.$storage.get('crossTable');\r\n\t\t\t\t\t\t\t\t\t\tawait this.$http({\r\n\t\t\t\t\t\t\t\t\t\t\turl: `${table}/update`,\r\n\t\t\t\t\t\t\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\t\t\t\t\t\t\tdata: obj\r\n\t\t\t\t\t\t\t\t\t\t}).then(({ data }) => {});\r\n\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\tawait this.$http({\r\n\t\t\t\t\t\t\t\turl: `smsregistercode/${!this.ruleForm.id ? \"save\" : \"update\"}`,\r\n\t\t\t\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\t\t\t\tdata: this.ruleForm\r\n\t\t\t\t\t\t\t}).then(async ({ data }) => {\r\n\t\t\t\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\t\t\t\tthis.$message({\r\n\t\t\t\t\t\t\t\t\t\tmessage: \"操作成功\",\r\n\t\t\t\t\t\t\t\t\t\ttype: \"success\",\r\n\t\t\t\t\t\t\t\t\t\tduration: 1500,\r\n\t\t\t\t\t\t\t\t\t\tonClose: () => {\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.showFlag = true;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.addOrUpdateFlag = false;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.smsregistercodeCrossAddOrUpdateFlag = false;\r\n\t\t\t\t\t\t\t\t\t\t\tthis.parent.search();\r\n\t\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t\t});\r\n\t\t\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t});\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t});\r\n\t\t\t},\r\n\t\t\t// 获取uuid\r\n\t\t\tgetUUID () {\r\n\t\t\t\treturn new Date().getTime();\r\n\t\t\t},\r\n\t\t\t// 返回\r\n\t\t\tback() {\r\n\t\t\t\tthis.parent.showFlag = true;\r\n\t\t\t\tthis.parent.addOrUpdateFlag = false;\r\n\t\t\t\tthis.parent.smsregistercodeCrossAddOrUpdateFlag = false;\r\n\t\t\t},\r\n\t\t}\r\n\t};\r\n</script>\r\n<style lang=\"scss\" scoped>\r\n\t.addEdit-block {\r\n\t\tpadding: 15px 30px 30px 30px;\r\n\t}\r\n\t.add-update-preview {\r\n\t\tborder-radius: 8px;\r\n\t\tpadding: 30px;\r\n\t\tmargin: 0 0 0px;\r\n\t\tbackground: #fff;\r\n\t\tdisplay: flex;\r\n\t\twidth: 100%;\r\n\t\tflex-wrap: wrap;\r\n\t}\r\n\t.amap-wrapper {\r\n\t\twidth: 100%;\r\n\t\thei