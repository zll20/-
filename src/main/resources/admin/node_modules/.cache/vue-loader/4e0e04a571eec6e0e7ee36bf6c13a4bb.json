pan class=\"tip-text\">{{dataList.length}}</span> 道。）\r\n\t\t\t</div>\r\n\t\t\t<div class=\"right-content\">\r\n\t\t\t\t考试剩余时间：\r\n\t\t\t\t<span class=\"tip-text\">{{SecondToDate}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"right-content\">\r\n\t\t\t\t<el-button type=\"danger\" round @click=\"leaveTap\">结束考试</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"detail-content\" v-if=\"!isEndFlag\">\r\n\t\t\t<div class=\"item-content\">\r\n\t\t\t\t<span class=\"label\">\r\n\t\t\t\t\t题目({{ruleForm.score}}分)：\r\n\t\t\t\t</span>\r\n\t\t\t\t<span class=\"content ql-snow ql-editor\" v-html=\"ruleForm.questionname\"></span>\r\n\t\t\t\t<el-tag type=\"success\" v-if=\"ruleForm.type==0\">单选题</el-tag>\r\n\t\t\t\t<el-tag type=\"warning\" v-if=\"ruleForm.type==1\">多选题</el-tag>\r\n\t\t\t\t<el-tag type=\"info\" v-if=\"ruleForm.type==2\">判断题</el-tag>\r\n\t\t\t\t<el-tag type=\"primary\" v-if=\"ruleForm.type==3\">填空题</el-tag>\r\n\t\t\t\t<el-tag type=\"danger\" v-if=\"ruleForm.type==4\">主观题</el-tag>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"(ruleForm.type==0||ruleForm.type==2)&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">选择答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-select v-model=\"answer\">\r\n\t\t\t\t\t\t<el-option\r\n\t\t\t\t\t\t\t:label=\"item.text\"\r\n\t\t\t\t\t\t\t:value=\"item.code\"\r\n\t\t\t\t\t\t\tv-for=\"(item,index) in options\"\r\n\t\t\t\t\t\t\tv-bind:key=\"index\"\r\n\t\t\t\t\t\t></el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==3&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-input v-model=\"answer\" style=\"width:300px\" placeholder=\"填写答案\" clearable></el-input>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==4&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-input v-model=\"answer\" type=\"textarea\" style=\"width:300px\" placeholder=\"填写答案\" clearable></el-input>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==1&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">选择答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-select v-model=\"answer\" multiple>\r\n\t\t\t\t\t\t<el-option\r\n\t\t\t\t\t\t\t:label=\"item.text\"\r\n\t\t\t\t\t\t\t:value=\"item.code\"\r\n\t\t\t\t\t\t\tv-for=\"(item,index) in options\"\r\n\t\t\t\t\t\t\tv-bind:key=\"index\"\r\n\t\t\t\t\t\t\t></el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div v-if=\"isSubmitFlag\" class=\"item-content\" style=\"border-top:1px solid #eeeeee\">\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">{{answer}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div v-if=\"isSubmitFlag\" class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<span\r\n\t\t\t\t\tv-if=\"ruleForm.type!=4\"\r\n\t\t\t\t\tclass=\"label\"\r\n\t\t\t\t\tstyle=\"color:red;margin-right:20px\"\r\n\t\t\t\t\t>{{ answer==this.ruleForm.answer?'正确':'错误'}}</span>\r\n\t\t\t\t<span class=\"label\">解析：</span>\r\n\t\t\t\t<span class=\"content\">{{ruleForm.analysis}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<el-button v-if=\"!isSubmitFlag\" @click=\"submitTap\" type=\"primary\">提交答案</el-button>\r\n\t\t\t\t<el-button v-if=\"isSubmitFlag\" @click=\"nextTap\" type=\"success\">下一题</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"detail-content\" v-if=\"isEndFlag\">\r\n\t\t\t<div class=\"item-content\">\r\n\t\t\t\t<span class=\"label\">\r\n\t\t\t\t\t考试成绩：\r\n\t\t\t\t\t<span style=\"font-size:24px;font-weight:blod;color:red\">{{this.score}}</span>\r\n\t\t\t\t</span>\r\n\t\t\t\t<span class=\"content\">分</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<el-button @click=\"finishTap\" type=\"primary\">结束考试</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</template>\r\n<script>\r\n\texport default {\r\n\t\tdata() {\r\n\t\t\treturn {\r\n\t\t\t\tdataList: [],\r\n\t\t\t\t// 当前题目\r\n\t\t\t\tpaper: {},\r\n\t\t\t\t// 当前答题下标\r\n\t\t\t\tcurrentIndex: 0,\r\n\t\t\t\truleForm: {},\r\n\t\t\t\t// 选项\r\n\t\t\t\toptions: null,\r\n\t\t\t\t// 用户选择答案\r\n\t\t\t\tanswer: \"\",\r\n\t\t\t\t// 得分\r\n\t\t\t\tscore: 0,\r\n\t\t\t\t// 倒计时定时器\r\n\t\t\t\tinter: null,\r\n\t\t\t\t// 倒计时时间\r\n\t\t\t\tcount: 0,\r\n\t\t\t\t// 是否提交点击下一题\r\n\t\t\t\tisSubmitFlag: false,\r\n\t\t\t\tuser: {},\r\n\t\t\t\t// 考试是否结束\r\n\t\t\t\tisEndFlag: false,\r\n\t\t\t\t// 是否存在主观题\r\n\t\t\t\thassubject: false,\r\n\t\t\t\texamno: '',\r\n\t\t\t\tnum: 0,\r\n\t\t\t};\r\n\t\t},\r\n\t\tcomputed: {\r\n\t\t\tSecondToDate: function() {\r\n\t\t\t\tvar time = this.count;\r\n\t\t\t\tif (null != time && \"\" != time) {\r\n\t\t\t\t\tif (time > 60 && time < 60 * 60) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 60.0) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt((parseFloat(time / 60.0) - parseInt(time / 60.0)) * 60) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else if (time >= 60 * 60 && time < 60 * 60 * 24) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 3600.0) +\r\n\t\t\t\t\t\t\"小时\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(\r\n\t\t\t\t\t\t\t(parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t  ) -\r\n\t\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t\t)) *\r\n\t\t\t\t\t\t\t60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else if (time >= 60 * 60 * 24) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 3600.0 / 24) +\r\n\t\t\t\t\t\t\"天\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0 / 24) - parseInt(time / 3600.0 / 24)) *\r\n\t\t\t\t\t\t\t24\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"小时\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(\r\n\t\t\t\t\t\t\t(parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t  ) -\r\n\t\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t\t)) *\r\n\t\t\t\t\t\t\t60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tif(parseInt(time)<=0) {\r\n\t\t\t\t\t\t\ttime = \"0秒\";\r\n\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\ttime = parseInt(time) + \"秒\";\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t\treturn time;\r\n\t\t\t}\r\n\t\t},\r\n\t\tdestroyed: function() {\r\n\t\t\twindow.clearInterval(this.inter);\r\n\t\t},\r\n\t\tmounted() {\r\n\t\t\tthis.examno = this.getUUID()\r\n\t\t\tthis.$http({\r\n\t\t\t\turl: `${this.$storage.get(\"sessionTable\")}/session`,\r\n\t\t\t\tmethod: \"get\"\r\n\t\t\t}).then(({ data }) => {\r\n\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\tthis.user = data.data;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t\tconsole.log(this.$route.params.id);\r\n\t\t\t// 获取 试题名称\r\n\t\t\tvar params = {\r\n\t\t\t\tpage: 1,\r\n\t\t\t\tlimit: 999,\r\n\t\t\t\tpaperid: this.$route.params.id\r\n\t\t\t};\r\n\t\t\tthis.$http({\r\n\t\t\t\turl: this.$api.examquestionpage,\r\n\t\t\t\tmethod: \"get\",\r\n\t\t\t\tparams: params\r\n\t\t\t}).then(({ data }) => {\r\n\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\tfor(let x in data.data.list){\r\n\t\t\t\t\t\tif(data.data.list[x].type==4){\r\n\t\t\t\t\t\t\tthis.hassubject = true\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tif(data.data.list[x].options){\r\n\t\t\t\t\t\t\tdata.data.list[x].optionList = JSON.parse(data.data.list[x].options)\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t\tdata.data.list[x].questionname = data.data.list[x].questionname.replace(/img src/gi,\"img style=\\\"width:100%;\\\" src\");\r\n\t\t\t\t\t}\r\n\t\t\t\t\tdata.data.list.sort(function (a, b) {\r\n\t\t\t\t\t\treturn (b.sequence - a.sequence)\r\n\t\t\t\t\t});\r\n\t\t\t\t\tthis.dataList = data.data.list;\r\n\t\t\t\t\tthis.ruleForm = this.dataList[this.currentIndex];\r\n\t\t\t\t\tthis.options = this.ruleForm.optionList\r\n\t\t\t\t} else {\r\n\t\t\t\t\tthis.dataList = [];\r\n\t\t\t\t}\r\n\t\t\t\tthis.dataListLoading = false;\r\n\t\t\t});\r\n\t\t\t// 获取英语测试\r\n\t\t\tthis.$http({\r\n\t\t\t\turl: `${this.$api.exampaperinfo}${this.$route.params.id}`,\r\n\t\t\t\tmethod: \"get\"\r\n\t\t\t}).then(({ data }) => {\r\n\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\tthis.paper = data.data;\r\n\t\t\t\t\tif (this.paper.time) {\r\n\t\t\t\t\t\tthis.count = this.paper.time*60;\r\n\t\t\t\t\t\tif (this.count > 0) {\r\n\t\t\t\t\t\t\tvar that = this;\r\n\t\t\t\t\t\t\tthis.inter = window.setInterval(function() {\r\n\t\t\t\t\t\t\t\tthat.count = that.count - 1;\r\n\t\t\t\t\t\t\t\tif (that.count < 0) {\r\n\t\t\t\t\t\t\t\t\twindow.clearInterval(that.inter);\r\n\t\t\t\t\t\t\t\t\tthat.isEndFlag = true;\r\n\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t}, 1000);\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t} else {\r\n\t\t\t\t\tthis.$message.error(data.msg);\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t},\r\n\t\tmethods: {\r\n\t\t\tgetUUID () {\r\n\t\t\t\treturn new Date().getTime();\r\n\t\t\t},\r\n\t\t\tleaveTap() {\r\n\t\t\t\tthis.$confirm(`确定离开考试?未答题目按0分计算`, \"提示\", {\r\n\t\t\t\t\tconfirmButtonText: \"确定\",\r\n\t\t\t\t\tcancelButtonText: \"取消\",\r\n\t\t\t\t\ttype: \"warning\"\r\n\t\t\t\t}).then(() => {\r\n\t\t\t\t\tthis.isEndFlag = true;\r\n\t\t\t\t});\r\n\t\t\t},\r\n\t\t\tfinishTap() {\r\n\t\t\t\tthis.$router.go(-1);\r\n\t\t\t},\r\n\t\t\tsubmitTap() {\r\n\t\t\t\tif(!this.answer) {\r\n\t\t\t\t\tthis.$message.error('请作答')\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\tlet myscore = 0;\r\n\t\t\t\tif (this.ruleForm.type == 1) {\r\n\t\t\t\t\tthis.answer = this.answer.sort().join(\",\");\r\n\t\t\t\t}\r\n\t\t\t\tthis.isSubmitFlag = true;\r\n\t\t\t\tthis.ruleForm.myanswer = this.answer\r\n\t\t\t\tif(this.ruleForm.type!=4){\r\n\t\t\t\t\tif (this.answer == this.ruleForm.answer) {\r\n\t\t\t\t\t\tthis.score = Number(this.score) +Number(this.ruleForm.score) ;\r\n\t\t\t\t\t\tthis.ruleForm.myscore = this.ruleForm.score;\r\n\t\t\t\t\t}else{\r\n\t\t\t\t\t\tthis.ruleForm.myscore = 0\r\n\t\t\t\t\t}\r\n\t\t\t\t}else{\r\n\t\t\t\t\tthis.ruleForm.myscore = 0\r\n\t\t\t\t}\r\n\t\t\t\tthis.saverecord(this.ruleForm)\r\n\t\t\t},\r\n\t\t\t// 保存答题记录\r\n\t\t\tsaverecord(row){\r\n\t\t\t\tlet record = {\r\n\t\t\t\t\tuserid: this.user.id,\r\n\t\t\t\t\tusername: this.$storage.get(\"examName\")?this.$storage.get(\"examName\"):'',\r\n\t\t\t\t\tpaperid: this.paper.id,\r\n\t\t\t\t\tpapername: this.paper.name,\r\n\t\t\t\t\tquestionid: row.id,\r\n\t\t\t\t\tquestionname: row.questionname,\r\n\t\t\t\t\toptions: row.options,\r\n\t\t\t\t\tscore: row.score,\r\n\t\t\t\t\tanswer: row.answer,\r\n\t\t\t\t\tanalysis: row.analysis,\r\n\t\t\t\t\tmyscore: row.myscore,\r\n\t\t\t\t\t\r\n\t\t\t\t\tmyanswer: row.myanswer,\r\n\t\t\t\t\ttype: row.type,\r\n\t\t\t\t\tismark: this.hassubject? 0 : 1,\r\n\t\t\t\t\texamno: this.examno,\r\n\t\t\t\t};\r\n\t\t\t\tthis.$http({\r\n\t\t\t\t\turl: `${this.$api.examrecordsave}`,\r\n\t\t\t\t\tmethod: \"post\",\r\n\t\t\t\t\tdata: record\r\n\t\t\t\t}).then(({\r\n\t\t\t\t\tdata\r\n\t\t\t\t}) => {});\r\n\t\t\t},\r\n\t\t\tasync nextTap() {\r\n\t\t\t\tif (this.currentIndex == this.dataList.length - 1) {\r\n\t\t\t\t\tthis.isEndFlag = true;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tthis.currentIndex = this.currentIndex + 1;\r\n\t\t\t\t\tthis.ruleForm = this.dataList[this.currentIndex];\r\n\t\t\t\t\tthis.options = JSON.parse(this.ruleForm.options);\r\n\t\t\t\t\tthis.isSubmitFlag = false;\r\n\t\t\t\t}\r\n\t\t\t\tthis.answer = \"\";\r\n\t\t\t},\r\n\t\t}\r\n\t};\r\n</script>\r\n<style lang=\"scss\" scoped>\r\n\t.container {\r\n\t\tborder: 1px solid #eeeeee;\r\n\t}\r\n\t\r\n\t.tip-text {\r\n\t\tfont-size: 24px;\r\n\t\tcolor: #f96332;\r\n\t}\r\n\t\r\n\t.top-content {\r\n\t\tdisplay: flex;\r\n\t\tjustify-content: space-between;\r\n\t\tpadding: 10px;\r\n\t\tfont-size: 18px;\r\n\t\tbackground: #409eff;\r\n\t\tcolor: #ffffff;\r\n\t\tborder-radius: 20px;\r\n\t}\r\n\t.detail-content {\r\n\t\tpadding: 20px;\r\n\t\tcolor: #333333;\r\n\t\r\n\t\t.item-content {\r\n\t\t\tpadding: 20px;\r\n\t\t}\r\n\t}\r\n</style>\r\n"]}]}