ype=\"textarea\" min=\"1\" v-model=\"dialogForm.text\" placeholder=\"ÕåģÕ«╣\" clearable></el-input>\r\n\t\t\t\t</el-form-item>\r\n\t\t\t</el-form>\r\n\t\t\t<span slot=\"footer\" class=\"dialog-footer\">\r\n\t\t\t\t<el-button @click=\"addOptionsDialogVisiable = false\">ÕÅ¢ µČł</el-button>\r\n\t\t\t\t<el-button type=\"primary\" @click=\"addOptions\">ńĪ« Õ«Ü</el-button>\r\n\t\t\t</span>\r\n\t\t</el-dialog>\r\n\t</div>\r\n</template>\r\n<script>\r\n\timport { isNumber } from \"@/utils/validate\";\r\n\texport default {\r\n\t\tdata() {\r\n\t\t\tvar validateNumber = (rule, value, callback) => {\r\n\t\t\t\tif (!isNumber(value)) {\r\n\t\t\t\t\tcallback(new Error(\"Ķ»ĘĶŠōÕģźµĢ░ÕŁŚ\"));\r\n\t\t\t\t} else {\r\n\t\t\t\t\tcallback();\r\n\t\t\t\t}\r\n\t\t\t};\r\n\t\t\treturn {\r\n\t\t\t\truleForm: {},\r\n\t\t\t\toptions: [],\r\n\t\t\t\taddOptionsDialogVisiable: false,\r\n\t\t\t\tdialogForm: {},\r\n\t\t\t\tpaperOptions: [],\r\n\t\t\t\tro: {\r\n\t\t\t\t},\r\n\t\t\t\tdialogRules: {\r\n\t\t\t\t\ttext: [{ required: true, message: \"Ķ»ĘÕĪ½ÕåÖÕåģÕ«╣\", trigger: \"blur\" }],\r\n\t\t\t\t\tcode: [{ required: true, message: \"Ķ»ĘķĆēµŗ®ķĆēķĪ╣\", trigger: \"blur\" }],\r\n\t\t\t\t},\r\n\t\t\t\trules: {\r\n\t\t\t\t\tpaperid: [{ required: true, message: \"Ķ»ĘķĆēµŗ®Ķ»ĢÕŹĘÕÉŹń¦░\", trigger: \"blur\" }],\r\n\t\t\t\t\tquestionname: [\r\n\t\t\t\t\t\t{ required: true, message: \"Ķ»ĢķóśÕÉŹń¦░ÕåģÕ«╣õĖŹĶāĮõĖ║ń®║\", trigger: \"blur\" }\r\n\t\t\t\t\t],\r\n\t\t\t\t\ttype: [{ required: true, message: \"Ķ»ĘķĆēµŗ®Ķ»ĢķóśÕÉŹń¦░ń▒╗Õ×ŗ\", trigger: \"blur\" }],\r\n\t\t\t\t\tsequence: [{ required: true, message: \"µÄÆÕ║ÅõĖŹĶāĮõĖ║ń®║\", trigger: \"blur\" }],\r\n\t\t\t\t\tanalysis: [\r\n\t\t\t\t\t\t{ required: true, message: \"Õłåµ×ÉõĖŹĶāĮõĖ║ń®║\", trigger: \"blur\" }\r\n\t\t\t\t\t],\r\n\t\t\t\t\tscore: [{ required: true, message: \"ÕłåµĢ░õĖŹĶāĮõĖ║ń®║\", trigger: \"blur\" }]\r\n\t\t\t\t},\r\n\t\t\t\teditIndex: -1\r\n\t\t\t};\r\n\t\t},\r\n\t\tprops: [\"parent\"],\r\n\t\tmethods: {\r\n\t\t\t// ÕłØÕ¦ŗÕī¢\r\n\t\t\tinit(id)