op=\"jibie\">\r\n\t\t\t\t<el-select v-model=\"ruleForm.jibie\" placeholder=\"请选择级别\">\r\n\t\t\t\t\t<el-option label=\"小学\" value=\"小学\"></el-option>\r\n\t\t\t\t\t<el-option label=\"初中\" value=\"初中\"></el-option>\r\n\t\t\t\t\t<el-option label=\"高中\" value=\"高中\"></el-option>\r\n\t\t\t\t\t<el-option label=\"四级\" value=\"四级\"></el-option>\r\n\t\t\t\t\t<el-option label=\"六级\" value=\"六级\"></el-option>\r\n\t\t\t\t\t<el-option label=\"考研\" value=\"考研\"></el-option>\r\n\t\t\t\t</el-select>\r\n\t\t\t</el-form-item>\r\n\r\n\t\t\t<el-form-item label=\"文刊内容\" prop=\"wenkanneirong\">\r\n\t\t\t\t<editor\r\n\t\t\t\t\t:style='{\"minHeight\":\"400px\"}'\r\n\t\t\t\t\tv-model=\"ruleForm.wenkanneirong\"\r\n\t\t\t\t\tclass=\"editor\"\r\n\t\t\t\t\t@blur=\"editorBlur\"\r\n\t\t\t\t\taction=\"file/upload\">\r\n\t\t\t\t</editor>\r\n\t\t\t</el-form-item>\r\n\r\n\t\t\t<el-form-item>\r\n\t\t\t\t<el-button class=\"submit-btn\" type=\"primary\" @click=\"onSubmit()\">提交</el-button>\r\n\t\t\t\t<el-button class=\"cancel-btn\" type=\"default\" @click=\"back()\">取消</el-button>\r\n\t\t\t</el-form-item>\r\n\t\t</el-form>\r\n\t</div>\r\n</template>\r\n\r\n<script>\r\nimport editor from \"@/components/common/Editor\";\r\nexport default {\r\n\tcomponents: { editor },\r\n\tdata() {\r\n\t\treturn {\r\n\t\t\tid: '',\r\n\t\t\truleForm: {\r\n\t\t\t\tmingcheng: '',\r\n\t\t\t\tjibie: '',\r\n\t\t\t\twenkanneirong: '',\r\n\t\t\t},\r\n\t\t\trules: {\r\n\t\t\t\tmingcheng: [\r\n\t\t\t\t\t{ required: true, message: '名称不能为空', trigger: 'blur' },\r\n\t\t\t\t],\r\n\t\t\t\tjibie: [\r\n\t\t\t\t\t{ required: true, message: '级别不能为空', trigger: 'blur' },\r\n\t\t\t\t],\r\n\t\t\t\twenkanneirong: [\r\n\t\t\t\t\t{ required: true, message: '文刊内容不能为空', trigger: 'blur' },\r\n\t\t\t\t],\r\n\t\t\t}\r\n\t\t}\r\n\t},\r\n\tcreated() {\r\n\t},\r\n\tmethods: {\r\n\t\tinit(id) {\r\n\t\t\tthis.id = id\r\n\t\t\tif (id) {\r\n\t\t\t\tthis.getInfo()\r\n\t\t\t}\r\n\t\t},\r\n\t\tgetInfo() {\r\n\t\t\tthis.$http({\r\n\t\t\t\turl: `wenkan/info/${this.id}`,\r\n\t\t\t\tmethod: 'get'\r\n\t\t\t}).then(({data}) => {\r\n\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\tthis.ruleForm = data.data\r\n\t\t\t\t}\r\n\t\t\t})\r\n\t\t},\r\n\t\teditorBlur(e) {\r\n\t\t\tthis.ruleForm.wenkanneirong = e\r\n\t\t},\r\n\t\tonSubmit() {\r\n\t\t\tthis.$refs[\"ruleForm\"].validate((valid) => {\r\n\t\t\t\tif (valid) {\r\n\t\t\t\t\tif (!this.id) {\r\n\t\t\t\t\t\tthis.$http({\r\n\t\t\t\t\t\t\turl: 'wenkan/save',\r\n\t\t\t\t\t\t\tmethod: 'post',\r\n\t\t\t\t\t\t\tdata: this.ruleForm\r\n\t\t\t\t\t\t}).then(({data}) => {\r\n\t\t\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\t\t\tthis.$message({\r\n\t\t\t\t\t\t\t\t\tmessage: '操作成功',\r\n\t\t\t\t\t\t\t\t\ttype: 'success',\r\n\t\t\t\t\t\t\t\t\tduration: 1500,\r\n\t\t\t\t\t\t\t\t\tonClose: () => {\r\n\t\t\t\t\t\t\t\t\t\tthis.$emit('refreshDataList')\r\n\t\t\t\t\t\t\t\t\t\tthis.$parent.showFlag = true\r\n\t\t\t\t\t\t\t\t\t\tthis.$parent.addOrUpdateVisible = false\r\n\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t})\r\n\t\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\t\tthis.$message.error(data.msg)\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t})\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tthis.$http({\r\n\t\t\t\t\t\t\turl: 'wenkan/update',\r\n\t\t\t\t\t\t\tmethod: 'post',\r\n\t\t\t\t\t\t\tdata: this.ruleForm\r\n\t\t\t\t\t\t}).then(({data}) => {\r\n\t\t\t\t\t\t\tif (data && data.code === 0) {\r\n\t\t\t\t\t\t\t\tthis.$message({\r\n\t\t\t\t\t\t\t\t\tmessage: '操作成功',\r\n\t\t\t\t\t\t\t\t\ttype: 'success',\r\n\t\t\t\t\t\t\t\t\tduration: 1500,\r\n\t\t\t\t\t\t\t\t\tonClose: () => {\r\n\t\t\t\t\t\t\t\t\t\tthis.$emit('refreshDataList')\r\n\t\t\t\t\t\t\t\t\t\tthis.$parent.showFlag = true\r\n\t\t\t\t\t\t\t\t\t\tthis.$parent.addOrUpdateVisible = false\r\n\t\t\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t\t\t})\r\n\t\t\t\t\t\t\t} else {\r\n\t\t\t\t\t\t\t\tthis.$message.error(data.msg)\r\n\t\t\t\t\t\t\t}\r\n\t\t\t\t\t\t})\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t})\r\n\t\t},\r\n\t\tback() {\r\n\t\t\tthis.$parent.showFlag = true\r\n\t\t\tthis.$parent.addOrUpdateVisible = false\r\n\t\t}\r\n\t}\r\n}\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.add-or-update {\r\n\tpadding: 20px;\r\n\tbackground: #fff;\r\n\tborder-radius: 8px;\r\n\r\n\t.submit-btn {\r\n\t\tborder: 0;\r\n\t\tcursor: pointer;\r\n\t\tborder-radius: 4px;\r\n\t\tpadding: 0 24px;\r\n\t\toutline: none;\r\n\t\tcolor: #fff;\r\n\t\tbackground: #FA6B04;\r\n\t\twidth: auto;\r\n\t\tfont-size: 16px;\r\n\t\theight: 40px;\r\n\t}\r\n\r\n\t.submit-btn:hover {\r\n\t\topacity: 0.8;\r\n\t}\r\n\r\n\t.cancel-btn {\r\n\t\tborder: 0;\r\n\t\tcursor: pointer;\r\n\t\tborder-radius: 4px;\r\n\t\tpadding: 0 24px;\r\n\t\toutline: none;\r\n\t\tcolor: #666;\r\n\t\tbackground: #f5f5f5;\r\n\t\twidth: auto;\r\n\t\tfont-size: 16px;\r\n\t\theight: 40px;\r\n\t}\r\n\r\n\t.cancel-btn:hover {\r\n\t\topacity: 0.8;\r\n\t}\r\n}\r\n</style>\r\n"]}]}