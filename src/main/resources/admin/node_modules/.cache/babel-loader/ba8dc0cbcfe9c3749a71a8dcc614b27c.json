"type","optionList","JSON","parse","questionname","replace","sort","a","b","sequence","dataListLoading","exampaperinfo","_ref3","that","setInterval","methods","Date","getTime","leaveTap","_this2","$confirm","confirmButtonText","cancelButtonText","finishTap","$router","go","submitTap","myscore","join","myanswer","Number","saverecord","row","record","userid","username","papername","name","questionid","analysis","ismark","examrecordsave","_ref4","nextTap","_this3","_asyncToGenerator","_regenerator","m","_callee","w","_context","n","length"],"sources":["src/views/modules/exampaperlist/exam.vue"],"sourcesContent":["<template>\r\n\t<div class=\"container\">\r\n\t\t<div class=\"top-content\">\r\n\t\t\t<div class=\"left-content\">\r\n\t\t\t\t当前第\r\n\t\t\t\t<span class=\"tip-text\">{{currentIndex+1}}</span> 道题。未答题目：\r\n\t\t\t\t<span class=\"tip-text\">{{dataList.length - currentIndex-1}}</span> 道，总题目：\r\n\t\t\t\t<span class=\"tip-text\">{{dataList.length}}</span> 道。\r\n\t\t\t</div>\r\n\t\t\t<div class=\"left-content\">\r\n\t\t\t\t{{paper.name}}（ 总题目：\r\n\t\t\t\t<span class=\"tip-text\">{{dataList.length}}</span> 道。）\r\n\t\t\t</div>\r\n\t\t\t<div class=\"right-content\">\r\n\t\t\t\t考试剩余时间：\r\n\t\t\t\t<span class=\"tip-text\">{{SecondToDate}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"right-content\">\r\n\t\t\t\t<el-button type=\"danger\" round @click=\"leaveTap\">结束考试</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"detail-content\" v-if=\"!isEndFlag\">\r\n\t\t\t<div class=\"item-content\">\r\n\t\t\t\t<span class=\"label\">\r\n\t\t\t\t\t题目({{ruleForm.score}}分)：\r\n\t\t\t\t</span>\r\n\t\t\t\t<span class=\"content ql-snow ql-editor\" v-html=\"ruleForm.questionname\"></span>\r\n\t\t\t\t<el-tag type=\"success\" v-if=\"ruleForm.type==0\">单选题</el-tag>\r\n\t\t\t\t<el-tag type=\"warning\" v-if=\"ruleForm.type==1\">多选题</el-tag>\r\n\t\t\t\t<el-tag type=\"info\" v-if=\"ruleForm.type==2\">判断题</el-tag>\r\n\t\t\t\t<el-tag type=\"primary\" v-if=\"ruleForm.type==3\">填空题</el-tag>\r\n\t\t\t\t<el-tag type=\"danger\" v-if=\"ruleForm.type==4\">主观题</el-tag>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"(ruleForm.type==0||ruleForm.type==2)&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">选择答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-select v-model=\"answer\">\r\n\t\t\t\t\t\t<el-option\r\n\t\t\t\t\t\t\t:label=\"item.text\"\r\n\t\t\t\t\t\t\t:value=\"item.code\"\r\n\t\t\t\t\t\t\tv-for=\"(item,index) in options\"\r\n\t\t\t\t\t\t\tv-bind:key=\"index\"\r\n\t\t\t\t\t\t></el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==3&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-input v-model=\"answer\" style=\"width:300px\" placeholder=\"填写答案\" clearable></el-input>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==4&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-input v-model=\"answer\" type=\"textarea\" style=\"width:300px\" placeholder=\"填写答案\" clearable></el-input>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div\r\n\t\t\t\tv-if=\"ruleForm.type==1&&!isSubmitFlag\"\r\n\t\t\t\tclass=\"item-content\"\r\n\t\t\t\tstyle=\"border-top:1px solid #eeeeee\"\r\n\t\t\t\t>\r\n\t\t\t\t<span class=\"label\">选择答案：</span>\r\n\t\t\t\t<span class=\"content\">\r\n\t\t\t\t\t<el-select v-model=\"answer\" multiple>\r\n\t\t\t\t\t\t<el-option\r\n\t\t\t\t\t\t\t:label=\"item.text\"\r\n\t\t\t\t\t\t\t:value=\"item.code\"\r\n\t\t\t\t\t\t\tv-for=\"(item,index) in options\"\r\n\t\t\t\t\t\t\tv-bind:key=\"index\"\r\n\t\t\t\t\t\t\t></el-option>\r\n\t\t\t\t\t</el-select>\r\n\t\t\t\t</span>\r\n\t\t\t</div>\r\n\t\t\t<div v-if=\"isSubmitFlag\" class=\"item-content\" style=\"border-top:1px solid #eeeeee\">\r\n\t\t\t\t<span class=\"label\">填写答案：</span>\r\n\t\t\t\t<span class=\"content\">{{answer}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div v-if=\"isSubmitFlag\" class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<span\r\n\t\t\t\t\tv-if=\"ruleForm.type!=4\"\r\n\t\t\t\t\tclass=\"label\"\r\n\t\t\t\t\tstyle=\"color:red;margin-right:20px\"\r\n\t\t\t\t\t>{{ answer==this.ruleForm.answer?'正确':'错误'}}</span>\r\n\t\t\t\t<span class=\"label\">解析：</span>\r\n\t\t\t\t<span class=\"content\">{{ruleForm.analysis}}</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<el-button v-if=\"!isSubmitFlag\" @click=\"submitTap\" type=\"primary\">提交答案</el-button>\r\n\t\t\t\t<el-button v-if=\"isSubmitFlag\" @click=\"nextTap\" type=\"success\">下一题</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t\t<div class=\"detail-content\" v-if=\"isEndFlag\">\r\n\t\t\t<div class=\"item-content\">\r\n\t\t\t\t<span class=\"label\">\r\n\t\t\t\t\t考试成绩：\r\n\t\t\t\t\t<span style=\"font-size:24px;font-weight:blod;color:red\">{{this.score}}</span>\r\n\t\t\t\t</span>\r\n\t\t\t\t<span class=\"content\">分</span>\r\n\t\t\t</div>\r\n\t\t\t<div class=\"item-content\" style=\"color:#888888\">\r\n\t\t\t\t<el-button @click=\"finishTap\" type=\"primary\">结束考试</el-button>\r\n\t\t\t</div>\r\n\t\t</div>\r\n\t</div>\r\n</template>\r\n<script>\r\n\texport default {\r\n\t\tdata() {\r\n\t\t\treturn {\r\n\t\t\t\tdataList: [],\r\n\t\t\t\t// 当前题目\r\n\t\t\t\tpaper: {},\r\n\t\t\t\t// 当前答题下标\r\n\t\t\t\tcurrentIndex: 0,\r\n\t\t\t\truleForm: {},\r\n\t\t\t\t// 选项\r\n\t\t\t\toptions: null,\r\n\t\t\t\t// 用户选择答案\r\n\t\t\t\tanswer: \"\",\r\n\t\t\t\t// 得分\r\n\t\t\t\tscore: 0,\r\n\t\t\t\t// 倒计时定时器\r\n\t\t\t\tinter: null,\r\n\t\t\t\t// 倒计时时间\r\n\t\t\t\tcount: 0,\r\n\t\t\t\t// 是否提交点击下一题\r\n\t\t\t\tisSubmitFlag: false,\r\n\t\t\t\tuser: {},\r\n\t\t\t\t// 考试是否结束\r\n\t\t\t\tisEndFlag: false,\r\n\t\t\t\t// 是否存在主观题\r\n\t\t\t\thassubject: false,\r\n\t\t\t\texamno: '',\r\n\t\t\t\tnum: 0,\r\n\t\t\t};\r\n\t\t},\r\n\t\tcomputed: {\r\n\t\t\tSecondToDate: function() {\r\n\t\t\t\tvar time = this.count;\r\n\t\t\t\tif (null != time && \"\" != time) {\r\n\t\t\t\t\tif (time > 60 && time < 60 * 60) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 60.0) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt((parseFloat(time / 60.0) - parseInt(time / 60.0)) * 60) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else if (time >= 60 * 60 && time < 60 * 60 * 24) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 3600.0) +\r\n\t\t\t\t\t\t\"小时\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(\r\n\t\t\t\t\t\t\t(parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t  ) -\r\n\t\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t\t)) *\r\n\t\t\t\t\t\t\t60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else if (time >= 60 * 60 * 24) {\r\n\t\t\t\t\t\ttime =\r\n\t\t\t\t\t\tparseInt(time / 3600.0 / 24) +\r\n\t\t\t\t\t\t\"天\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0 / 24) - parseInt(time / 3600.0 / 24)) *\r\n\t\t\t\t\t\t\t24\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"小时\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"分钟\" +\r\n\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t  (parseFloat(\r\n\t\t\t\t\t\t\t(parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t  ) -\r\n\t\t\t\t\t\t\tparseInt(\r\n\t\t\t\t\t\t\t  (parseFloat(time / 3600.0) - parseInt(time / 3600.0)) * 60\r\n\t\t\t\t\t\t\t)) *\r\n\t\t\t\t\t\t\t60\r\n\t\t\t\t\t\t) +\r\n\t\t\t\t\t\t\"秒\";\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tif(parseInt(