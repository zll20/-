称\">\r\n        <el-input v-model=\"dataForm.mingcheng\" disabled></el-input>\r\n      </el-form-item>\r\n      <el-form-item label=\"级别\">\r\n        <el-input v-model=\"dataForm.jibie\" disabled></el-input>\r\n      </el-form-item>\r\n      <el-form-item label=\"听力音频\">\r\n        <div v-if=\"dataForm.shiyinshipin\">\r\n          <audio controls style=\"width: 100%;\">\r\n            <source :src=\"getAudioUrl()\" type=\"audio/mpeg\">\r\n          </audio>\r\n        </div>\r\n        <div v-else>暂无音频</div>\r\n      </el-form-item>\r\n    </el-form>\r\n    <span slot=\"footer\" class=\"dialog-footer\">\r\n      <el-button @click=\"visible = false\">关闭</el-button>\r\n    </span>\r\n  </el-dialog>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  data() {\r\n    return {\r\n      visible: false,\r\n      dataForm: {\r\n        id: '',\r\n        mingcheng: '',\r\n        jibie: '',\r\n        shiyinshipin: ''\r\n      }\r\n    }\r\n  },\r\n  methods: {\r\n    init(id) {\r\n      this.visible = true\r\n      this.dataForm = {\r\n        id: '',\r\n        mingcheng: '',\r\n        jibie: '',\r\n        shiyinshipin: ''\r\n      }\r\n      if (id) {\r\n        this.$http({\r\n          url: `tingli/info/${id}`,\r\n          method: 'get'\r\n        }).then(({data}) => {\r\n          if (data && data.code === 0) {\r\n            this.dataForm = data.tingli || {\r\n              id: '',\r\n              mingcheng: '',\r\n              jibie: '',\r\n              shiyinshipin: ''\r\n            }\r\n          }\r\n        }).catch(error => {\r\n          console.error('获取听力信息失败:', error)\r\n        })\r\n      }\r\n    },\r\n    getAudioUrl() {\r\n      if (!this.dataForm.shiyinshipin) {\r\n        return '';\r\n      }\r\n      let url = this.dataForm.shiyinshipin;\r\n\r\n      // 清理所有前导斜杠\r\n      while (url.startsWith('/')) {\r\n        url = url.substring(1);\r\n      }\r\n\r\n      // 清理所有重复的 upload/ 前缀\r\n      while (url.startsWith('upload/upload/')) {\r\n        url = url.substring(7);\r\n      }\r\n\r\n      if (url.startsWith('http')) {\r\n        return url;\r\n      }\r\n      return this.$base.url + url;\r\n    }\r\n  }\r\n}\r\n</script>"],"mappings":";AAyBA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,OAAA;MACAC,QAAA;QACAC,EAAA;QACAC,SAAA;QACAC,KAAA;QACAC,YAAA;MACA;IACA;EACA;EACAC,OAAA;IACAC,IAAA,WAAAA,KAAAL,EAAA;MAAA,IAAAM,KAAA;MACA,KAAAR,OAAA;MACA,KAAAC,QAAA;QACAC,EAAA;QACAC,SAAA;QACAC,KAAA;QACAC,YAAA;MACA;MACA,IAAAH,EAAA;QACA,KAAAO,KAAA;UACAC,GAAA,iBAAAC,MAAA,CAAAT,EAAA;UACAU,MAAA;QACA,GAAAC,IAAA,WAAAC,IAAA;UAAA,IAAAf,IAAA,GAAAe,IAAA,CAAAf,IAAA;UACA,IAAAA,IAAA,IAAAA,IAAA,CAAAgB,IAAA;YACAP,KAAA,CAAAP,QAAA,GAAAF,IAAA,CAAAiB,MAAA;cACAd,EAAA;cACAC,SAAA;cACAC,KAAA;cACAC,YAAA;YACA;UACA;QACA,GAAAY,KAAA,WAAAC,KAAA;UACAC,OAAA,CAAAD,KAAA,cAAAA,KAAA;QACA;MACA;IACA;IACAE,WAAA,WAAAA,YAAA;MACA,UAAAnB,QAAA,CAAAI,YAAA;QACA;MACA;MACA,IAAAK,GAAA,QAAAT,QAAA,CAAAI,YAAA;;MAEA;MACA,OAAAK,GAAA,CAAAW,UAAA;QACAX,GAAA,GAAAA,GAAA,CAAAY,SAAA;MACA;;MAEA;MACA,OAAAZ,GAAA,CAAAW,UAAA;QACAX,GAAA,GAAAA,GAAA,CAAAY,SAAA;MACA;MAEA,IAAAZ,GAAA,CAAAW,UAAA;QACA,OAAAX,GAAA;MACA;MACA,YAAAa,KAAA,CAAAb,GAAA,GAAAA,GAAA;IACA;EACA;AACA","ignoreList":[]}]}