\":\"none\",\"width\":\"100%\",\"borderStyle\":\"solid\"}' \r\n\t\t\t\t\t:border='false'\r\n\t\t\t\t\t:data=\"dataList\"\n\t\t\t\t\tv-loading=\"dataListLoading\"\n\t\t\t\t\t@selection-change=\"selectionChangeHandler\">\r\n\t\t\t\t\t<el-table-column :resizable='true' type=\"selection\" align=\"center\" width=\"50\"></el-table-column>\n\t\t\t\t\t<el-table-column :resizable='true' :sortable='true' label=\"序号\" type=\"index\" width=\"50\" />\r\n\t\t\t\t\t<el-table-column :resizable='true' :sortable='true'\r\n\t\t\t\t\t\t\t\t\t\t\t\tprop=\"nickname\"\n\t\t\t\t\t\tlabel=\"用户名\">\n\t\t\t\t\t\t<template slot-scope=\"scope\">\n\t\t\t\t\t\t\t{{scope.row.nickname}}\r\n\t\t\t\t\t\t</template>\n\t\t\t\t\t</el-table-column>\n\t\t\t\t\t<el-table-column :resizable='true' :sortable='true' prop=\"content\" label=\"评论内容\">\r\n\t\t\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t\t\t<span class=\"ql-snow ql-editor\" v-html=\"scope.row.content\"></span>\r\n\t\t\t\t\t\t</template>\r\n\t\t\t\t\t</el-table-column>\n\t\t\t\t\t<el-table-column :resizable='true' :sortable='true' prop=\"reply\" label=\"回复内容\">\r\n\t\t\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t\t\t<span class=\"ql-snow ql-editor\" v-html=\"scope.row.reply\"></span>\r\n\t\t\t\t\t\t</template>\r\n\t\t\t\t\t</el-table-column>\n\t\t\t\t\t<el-table-column :resizable='true' :sortable='true' prop=\"istop\" label=\"是否置顶\">\r\n\t\t\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t\t\t<el-switch\r\n\t\t\t\t\t\t\t\tv-model=\"scope.row.istop\"\r\n\t\t\t\t\t\t\t\t:width=\"36\"\r\n\t\t\t\t\t\t\t\tactive-icon-class=\"el-icon-edit\"\r\n\t\t\t\t\t\t\t\tinactive-icon-class=\"el-icon-share\"\r\n\t\t\t\t\t\t\t\tactive-text=\"开\"\r\n\t\t\t\t\t\t\t\tinactive-text=\"关\"\r\n\t\t\t\t\t\t\t\t:active-value=\"1\"\r\n\t\t\t\t\t\t\t\t:inactive-value=\"0\"\r\n\t\t\t\t\t\t\t\tactive-color=\"#FA6B04\"\r\n\t\t\t\t\t\t\t\tinactive-color=\"#ccc\"\r\n\t\t\t\t\t\t\t\t@change=\"(e)=>discussistopChange(e,scope.row)\">\r\n\t\t\t\t\t\t\t</el-switch>\r\n\t\t\t\t\t\t</template>\r\n\t\t\t\t\t</el-table-column>\r\n\t\t\t\t\t<el-table-column width=\"300\" label=\"操作\">\n\t\t\t\t\t\t<template slot-scope=\"scope\">\r\n\t\t\t\t\t\t\t<el-button class=\"edit\" v-if=\" isAuth('discussdanciku','修改') \" type=\"success\" @click=\"addOrUpdateHandler(scope.row.id)\">\r\n\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-xiugai13\" :style='{\"margin\":\"0 0px\",\"fontSize\":\"14px\",\"color\":\"rgba(255, 140, 0, 1)\",\"display\":\"none\",\"height\":\"40px\"}'></span>\r\n\t\t\t\t\t\t\t\t修改\r\n\t\t\t\t\t\t\t</el-button>\n\n\t\t\t\t\t\t\t<el-button class=\"view\" v-if=\"isAuth('discussdanciku','查看评论')\" type=\"success\" @click=\"disscussListHandler(scope.row.id)\">\r\n\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-chakan2\" :style='{\"margin\":\"0 0px\",\"fontSize\":\"14px\",\"color\":\"#333\",\"display\":\"none\",\"height\":\"40px\"}'></span>\r\n\t\t\t\t\t\t\t\t查看评论\r\n\t\t\t\t\t\t\t</el-button>\n\n\n\t\t\t\t\t\t\t<el-button class=\"btn8\" type=\"success\" @click=\"addOrUpdateHandler(scope.row.id)\">\r\n\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-huifu18\" :style='{\"margin\":\"0 0px\",\"fontSize\":\"14px\",\"color\":\"#333\",\"display\":\"none\",\"height\":\"40px\"}'></span>\r\n\t\t\t\t\t\t\t\t回复\r\n\t\t\t\t\t\t\t</el-button>\n\n\t\t\t\t\t\t\t<el-button class=\"del\" v-if=\"isAuth('danciku','删除评论')\" type=\"primary\" @click=\"deleteHandler(scope.row.id ,scope.row.refid)\">\r\n\t\t\t\t\t\t\t\t<span class=\"icon iconfont icon-shanchu6\" :style='{\"margin\":\"0 0px\",\"fontSize\":\"14px\",\"color\":\"rgba(220, 38, 38, 1)\",\"display\":\"none\",\"height\":\"40px\"}'></span>\r\n\t\t\t\t\t\t\t\t删除\r\n\t\t\t\t\t\t\t</el-button>\r\n\t\t\t\t\t\t</template>\n\t\t\t\t\t</el-table-column>\n\t\t\t\t</el-table>\n\t\t\t</div>\r\n\t\t\t<el-pagination\r\n\t\t\t\t@size-change=\"sizeChangeHandle\"\n\t\t\t\t@current-change=\"currentChangeHandle\"\n\t\t\t\t:current-page=\"pageIndex\"\n\t\t\t\tbackground\r\n\t\t\t\t:page-sizes=\"[10, 50, 100, 200]